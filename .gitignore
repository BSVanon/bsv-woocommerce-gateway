# Docker WordPress installations (full WP installs, not part of plugin)
docker/wp/
docker/wp-modern/
docker/wp-legacy/

# Local documentation (only publish key guides referenced in README)
/docs/*
!/docs/
!/docs/TESTING.md
!/docs/RELEASE_NOTES.md
!/docs/DEV_NOTES.md
!/docs/CAPABILITIES.md

# Plugin debug log
__log.php

# Build artifacts (large zip files for distribution)
*.zip

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.code-workspace

# Test and development files
test-*.php
diagnose-*.php

# Docker compose files (keep in local only)
docker-compose*.yml
